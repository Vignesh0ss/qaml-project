# Flask
FLASK_ENV=development
SECRET_KEY=generate-with-secrets.token_hex-32
JWT_SECRET_KEY=generate-with-secrets.token_hex-32
JWT_ACCESS_TOKEN_EXPIRES=3600

# MongoDB (connectTimeoutMS/socketTimeoutMS are appended automatically if omitted)
MONGO_URI=mongodb://localhost:27017/
MONGODB_DB=quantum_drug_repurposing

# CORS — required in production (comma-separated). Dev defaults to * if unset.
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Redis / Celery (optional)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Quantum (optional)
USE_CLOUD_QUANTUM=false
# DWAVE_API_TOKEN=
# DWAVE_SOLVER=Advantage_system6.4

# ML
# ML_MODEL_PATH=backend/ml/artifacts/model.joblib
# MLFLOW_TRACKING_URI=

# Frontend (Vite) — copy to frontend/.env.production for Vercel or local prod build
# API origin only (no /api/v1); the client adds /api/v1 to requests.
# VITE_API_BASE_URL=https://your-service.onrender.com
