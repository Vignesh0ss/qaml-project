        drugs = [
            {"molregno": "TEST_1", "canonical_smiles": "C", "standard_value": "50.0", "target_name": "TestDrug1"},
            {"molregno": "TEST_2", "canonical_smiles": "CC", "standard_value": "60.0", "target_name": "TestDrug2"},
            {"molregno": "TEST_3", "canonical_smiles": "CCC", "standard_value": "70.0", "target_name": "TestDrug3"},
        ]
        m5.return_value = (drugs, np.array([50.0, 60.0, 70.0]), ["C", "CC", "CCC"])
        m6.return_value = np.zeros((3, 3))
        
        yield (m1, m2, m3, m4, m5, m6)
