         patch("app.services.gemini_service.generate_medical_summary") as m3, \
         patch("app.services.gemini_service._generate") as m4, \
         patch("app.services.pipeline.load_candidates") as m5, \
         patch("app.services.pipeline.get_overlap_matrix") as m6:
        
        m1.return_value = {
            "canonical_name": "Mock Disease",
            "description": "A mocked disease for testing.",
            "icd_code": "M0CK"
        }
        m2.return_value = [
            {
                "molregno": "MOCK_1",
                "canonical_smiles": "C",
                "standard_value": "90.0",
                "target_name": "MockDrug",
                "target_chembl_id": "",
